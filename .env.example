# --- Reddit API (script-type app: https://www.reddit.com/prefs/apps) ---
# Phase 1 uses the client_credentials grant (app-only, read-only public data) --
# no Reddit account password required. See README for why.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=claude-radar/0.1 by u/YOUR_USERNAME
# Only used if you switch to the password grant (not used by default):
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# --- Privacy ---
HASH_AUTHORS=true
AUTHOR_HASH_PEPPER=change-me-to-a-random-string

# --- Collector tuning ---
POLL_INTERVAL_SECONDS=7200
TOP_N=50
VELOCITY_THRESHOLD=10
RAW_TEXT_RETENTION_DAYS=14
# A quiet gap longer than this (hours) starts a new "episode" when counting
# how many times a root-cause cluster has recurred -- see radar/cluster.py.
RECURRENCE_GAP_HOURS=48

# Which categories require human QA before an alert is trusted, and any
# per-category velocity-threshold override, now live in
# config/escalation_criteria.yaml (dashboard-editable, Settings tab) instead
# of an env var -- see that file or GET /api/escalation-criteria.

# --- Storage ---
DATABASE_PATH=data/radar.db

# --- Classifier ---
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
CLASSIFY_BATCH_LIMIT=100

# --- YouTube (Data API v3, simple API-key auth -- see README) ---
YOUTUBE_API_KEY=

# --- X/Twitter (feature-flagged -- off by default even if a token is set; see README) ---
ENABLE_X_SOURCE=false
X_BEARER_TOKEN=

# --- Hacker News (Algolia HN Search API -- free, keyless; off by default) ---
ENABLE_HACKERNEWS_SOURCE=false

# --- Stack Overflow (Stack Exchange API -- free, key optional; off by default) ---
ENABLE_STACKOVERFLOW_SOURCE=false
STACKOVERFLOW_API_KEY=

# --- GitHub Issues (needs a personal access token; see README) ---
GITHUB_TOKEN=

# --- Mastodon (one configured instance's /api/v2/search; needs a bearer token) ---
MASTODON_INSTANCE_URL=
MASTODON_ACCESS_TOKEN=
