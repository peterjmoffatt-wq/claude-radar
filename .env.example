# --- Reddit API (script-type app: https://www.reddit.com/prefs/apps) ---
# Phase 1 uses the client_credentials grant (app-only, read-only public data) --
# no Reddit account password required. See README for why.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=claude-radar/0.1 by u/YOUR_USERNAME
# Only used if you switch to the password grant (not used by default):
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# --- Privacy ---
HASH_AUTHORS=true
AUTHOR_HASH_PEPPER=change-me-to-a-random-string

# --- Collector tuning ---
POLL_INTERVAL_SECONDS=7200
TOP_N=50
VELOCITY_THRESHOLD=10
RAW_TEXT_RETENTION_DAYS=14
# Scoped to issue TYPES only -- never specific people or communities.
HUMAN_QA_CATEGORIES=["abuse","credential_theft","safety"]

# --- Storage ---
DATABASE_PATH=data/radar.db

# --- Classifier (Phase 2 -- not implemented yet; value referenced now so config doesn't need rework) ---
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
